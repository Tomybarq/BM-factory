          "then": "end",
          "x-base44": {
            "title": "\u062a\u0635\u062f\u064a\u0631 \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631",
            "description": "\u0643\u062a\u0627\u0628\u0629 \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631 \u0644\u0644\u0634\u064a\u062a"
          }
