      }
    ]
  },
  "name": "\u0645\u0632\u0627\u0645\u0646\u0629 \u062c\u0648\u062c\u0644 \u0634\u064a\u062a\u0633 \u0627\u0644\u062a\u0644\u0642\u0627\u0626\u064a\u0629"
